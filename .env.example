# Copy to .env before first run
POSTGRES_DB=risk_crm
POSTGRES_USER=risk_user
POSTGRES_PASSWORD=risk_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Used inside Docker network
DATABASE_URL=postgresql+psycopg://risk_user:risk_password@db:5432/risk_crm

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Optional local URL if you run Alembic from host machine
LOCAL_DATABASE_URL=postgresql+psycopg://risk_user:risk_password@localhost:5432/risk_crm 